[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://addons/safenest_ui/editor/dock_panel.gd" id="1"]

[node name="SafeNestDock" type="VBoxContainer"]
offset_right = 300.0
offset_bottom = 400.0
script = ExtResource("1")

[node name="Title" type="Label" parent="."]
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "SafeNest UI"
horizontal_alignment = 1

[node name="Separator1" type="HSeparator" parent="."]
layout_mode = 2

[node name="ProfileLabel" type="Label" parent="."]
layout_mode = 2
text = "Simulation Profile:"

[node name="ProfileDropdown" type="OptionButton" parent="."]
unique_name_in_owner = true
layout_mode = 2

[node name="ProfileInfoLabel" type="Label" parent="."]
unique_name_in_owner = true
layout_mode = 2
text = "Res: 1080x1920
Margins: Top:44, Bottom:34"
autowrap_mode = 2
theme_override_colors/font_color = Color(0.7, 0.7, 0.7, 1)

[node name="PreviewButton" type="Button" parent="."]
unique_name_in_owner = true
layout_mode = 2
text = "Preview Profile (Overlay)"

[node name="ApplyResButton" type="Button" parent="."]
unique_name_in_owner = true
layout_mode = 2
text = "Apply Resolution To Project"

[node name="WarningLabel" type="Label" parent="."]
layout_mode = 2
theme_override_colors/font_color = Color(0.85, 0.65, 0.2, 1)
theme_override_font_sizes/font_size = 11
text = "Applying will modify Project Settings window size."
autowrap_mode = 2

[node name="Separator2" type="HSeparator" parent="."]
layout_mode = 2

[node name="SelectedNodeLabel" type="Label" parent="."]
unique_name_in_owner = true
layout_mode = 2
text = "Selected: (none)"
autowrap_mode = 2

[node name="MarginSpacer" type="Control" parent="."]
custom_minimum_size = Vector2(0, 8)
layout_mode = 2

[node name="PlacementLabel" type="Label" parent="."]
layout_mode = 2
theme_override_font_sizes/font_size = 12
text = "Smart Placement:"

[node name="PlacementDropdown" type="OptionButton" parent="."]
unique_name_in_owner = true
layout_mode = 2

[node name="ApplyLayoutButton" type="Button" parent="."]
unique_name_in_owner = true
layout_mode = 2
text = "Apply Safe Layout to Node(s)"

[node name="MarginSpacer2" type="Control" parent="."]
custom_minimum_size = Vector2(0, 4)
layout_mode = 2

[node name="StatusLabel" type="Label" parent="."]
unique_name_in_owner = true
layout_mode = 2
